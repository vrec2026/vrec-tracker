      : "";
    el.innerHTML = '<div style="padding:10px 14px;background:#DCFCE7;border:1px solid #166534;border-radius:8px;font-size:13px;color:#166534;font-weight:600">&#10003; Connected to Firebase - data saves automatically</div>' + urlHint;
  } else if (fbConfig) {
    el.innerHTML = '<div style="padding:10px 14px;background:#FEF3DC;border:1px solid #C07D14;border-radius:8px;font-size:13px;color:#C07D14">Config found - fill in fields below and click Connect</div>';
