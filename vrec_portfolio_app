function loadScript(src, cb) {
  var s = document.createElement("script");
  s.src = src;
  s.onload = cb;
  s.onerror = function() { cb(new Error("Failed to load " + src)); };
  document.head.appendChild(s);
}
function connectFirebase() {
  var apiKey = document.getElementById("fb-apiKey").value.trim();
  var authDomain = document.getElementById("fb-authDomain").value.trim();
  var databaseURL = document.getElementById("fb-dbURL").value.trim();
  var projectId = document.getElementById("fb-projectId").value.trim();
  if (!apiKey || !authDomain || !databaseURL || !projectId) {
    toast("Please fill in all 4 fields", true); return;
  }
  var cfg = {apiKey:apiKey,authDomain:authDomain,databaseURL:databaseURL,projectId:projectId};
  var btn = document.getElementById("fbConnBtn");
  btn.textContent = "Connecting..."; btn.disabled = true;
  loadScript("https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js", function(e1) {
    if (e1 instanceof Error) { toast("Could not load Firebase SDK", true); btn.textContent="Connect to Firebase"; btn.disabled=false; return; }
    loadScript("https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js", function(e2) {
      if (e2 instanceof Error) { toast("Could not load Firebase Database SDK", true); btn.textContent="Connect to Firebase"; btn.disabled=false; return; }
      try {
        if (window.firebase && window.firebase.apps && window.firebase.apps.length) {
          window.firebase.app().delete().then(function() { doInit(cfg, btn); });
        } else {
          doInit(cfg, btn);
        }
      } catch(err) { doInit(cfg, btn); }
    });
  });
}
function doInit(cfg, btn) {
  try {
    window.firebase.initializeApp(cfg);
    fbDB = window.firebase.database();
    fbDB.ref(".info/connected").once("value", function(snap) {
      fbReady = true;
      fbConfig = cfg;
      try { localStorage.setItem("vrec_fb", JSON.stringify(cfg)); } catch(e) {}
      // Also encode in URL hash so iframe can retrieve on reload
      try {
        var encoded = encodeURIComponent(JSON.stringify(cfg));
        if (window.history && window.history.replaceState) {
          window.history.replaceState(null, "", "#fb=" + encoded);
        } else {
          window.location.hash = "fb=" + encoded;
        }
      } catch(e) {}
      btn.textContent = "Connected!"; btn.disabled = false;
      toast("Connected to Firebase!", false);
      renderFbStatus();
      loadFromFirebase();
    }, function(err) {
      toast("Connection failed: " + err.message, true);
      btn.textContent = "Connect to Firebase"; btn.disabled = false;
    });
  } catch(err) {
    toast("Init error: " + err.message, true);
    btn.textContent = "Connect to Firebase"; btn.disabled = false;
  }
}
function loadFromFirebase() {
  if (!fbReady || !fbDB) return;
  fbDB.ref("vrec").once("value", function(snap) {
    var data = snap.val();
    if (data && data.properties && data.properties.length > 0) {
      S = data;
      for (var i=0; i<S.properties.length; i++) {
        if (!S.properties[i].notes) S.properties[i].notes = "";
      }
      renderDash();
      renderEntry();
      toast("Data loaded from Firebase", false);
    } else {
      fbDB.ref("vrec").set(S);
    }
  });
}
function saveData() {
  var btn = document.getElementById("saveBtn");
  btn.textContent = "Saving..."; btn.disabled = true;
  if (fbReady && fbDB) {
    fbDB.ref("vrec").set(S, function(err) {
      if (err) {
        toast("Save failed: " + err.message, true);
        btn.textContent = "Save"; btn.disabled = false;
      } else {
        toast("Saved to Firebase!", false);
        btn.textContent = "Saved!"; btn.disabled = false;
        setTimeout(function(){ btn.textContent = "Save"; }, 2000);
      }
    });
  } else {
    try { localStorage.setItem("vrec_local", JSON.stringify(S)); } catch(e) {}
    toast("Saved locally (Firebase not connected)", true);
    btn.textContent = "Save"; btn.disabled = false;
  }
}
function renderFbStatus() {
  var el = document.getElementById("fbStatus");
  if (!el) return;
  if (fbReady) {
    var curUrl = "";
    try { curUrl = window.location.href; } catch(e) {}
