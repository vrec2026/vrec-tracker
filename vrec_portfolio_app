  html+='<div class="d-sec">'+curMonth+' Figures</div>';
  html+='<div class="d-row"><span class="d-key">Income</span><span class="d-val" style="color:#0C6349">'+(inc>0?fmt(inc):"$0.00")+'</span></div>';
  html+='<div class="d-row"><span class="d-key">Expected</span><span class="d-val">'+(pr.exp>0?fmt(pr.exp):"N/A")+'</span></div>';
  html+='<div class="d-row"><span class="d-key">Variance</span><span class="d-val" style="color:'+(inc-pr.exp>=0?"#0C6349":"#B02A2A")+'">'+fmt(inc-pr.exp)+'</span></div>';
  html+='<div class="d-row"><span class="d-key">Lien Paid</span><span class="d-val">'+(lien>0?fmt(lien):"$0.00")+'</span></div>';
  html+='<div class="d-row"><span class="d-key">Lien Due</span><span class="d-val">'+(pr.lienDue>0?fmt(pr.lienDue):"N/A")+'</span></div>';
  html+='<div class="d-row"><span class="d-key">Net</span><span class="d-val" style="color:'+(net>=0?"#0C6349":"#B02A2A")+'">'+(net<0?"-":"")+fmt(Math.abs(net))+'</span></div>';
  if(pr.notes) html+='<div style="margin-top:8px;padding:8px;background:#FEF3DC;border-radius:6px;font-size:11px;color:#7C4A00">'+pr.notes+'</div>';
  html+='<div class="d-sec">Quick Edit</div>';
  html+='<div style="font-size:11px;color:#7A7870;margin-bottom:2px">Income Received ($)</div>';
  html+='<input class="d-inp" type="number" id="de-inc" value="'+(inc||'')+'" placeholder="0.00">';
  html+='<div style="font-size:11px;color:#7A7870;margin-top:8px;margin-bottom:2px">Lien Paid ($)</div>';
  html+='<input class="d-inp" type="number" id="de-lien" value="'+(lien||'')+'" placeholder="0.00">';
  html+='<button class="d-btn" onclick="saveDetail(\''+safe+'\')">Save Changes</button>';
  html+='<button class="d-btn2" onclick="showTab(\'manage\',null);openMgrFor(\''+safe+'\');closeDetail()">Edit All Details</button>';
  document.getElementById("detailInner").innerHTML=html;
  document.getElementById("detailPanel").classList.add("open");
}
function closeDetail(){document.getElementById("detailPanel").classList.remove("open");}
function quickType(name,val) {
  for(var i=0;i<S.properties.length;i++){if(S.properties[i].p===name){S.properties[i].t=val;break;}}
  var el=document.getElementById("type-confirm");
  if(el){el.style.display="block";setTimeout(function(){el.style.display="none";},2000);}
  renderDash();
  toast(name+" type changed to "+val, false);
}
function quickLienSt(name,val) {
  for(var i=0;i<S.properties.length;i++){if(S.properties[i].p===name){S.properties[i].lienSt=val;break;}}
  var el=document.getElementById("lienst-confirm");
  if(el){el.style.display="block";setTimeout(function(){el.style.display="none";},2000);}
  renderDash();
  toast(name+" lien status changed to "+val, false);
}
function saveDetail(name) {
  var md=getMD(curMonth);
  var inc=parseFloat(document.getElementById("de-inc").value)||0;
  var lien=parseFloat(document.getElementById("de-lien").value)||0;
  if(inc>0) md.income[name]=inc; else delete md.income[name];
  if(lien>0) md.lien[name]=lien; else delete md.lien[name];
  saveData();
  renderDash();
  showDetail(name);
}

// ═══════════════════════════════════════
// ENTRY TAB
// ═══════════════════════════════════════
function renderEntry() {
  var md=getMD(curMonth);
  var active=[];
  for(var i=0;i<S.properties.length;i++){
    var p=S.properties[i];
    if(p.t!=="LAND"&&p.t!=="OTHER") active.push(p);
  }
  var ih="";
  for(var i=0;i<active.length;i++){
    var pr=active[i];
    var v=md.income[pr.p]||"";
    ih+='<div class="erow">';
    ih+='<div class="eprop" title="'+pr.p+'">'+pr.p+'</div>';
    ih+='<input class="einp'+(v?" filled":"")+'" type="number" placeholder="'+(pr.exp||"0.00")+'" value="'+v+'" data-prop="'+pr.p+'" data-type="income" oninput="updateEntry(this)">';
    ih+='<select class="esel'+(v?" yes":" no")+'" onchange="this.className=\'esel \'+(this.value===\'YES\'?\'yes\':\'no\')">';
    ih+='<option'+(v?" selected":"")+' value="YES">YES</option><option'+(!v?" selected":"")+' value="NO">NO</option></select>';
    ih+='</div>';
  }
  document.getElementById("incList").innerHTML=ih;
  var lienProps=[];
  for(var i=0;i<S.properties.length;i++){
    var p=S.properties[i];
    if(p.lienSt==="ACTIVE"&&p.lienDue>0) lienProps.push(p);
  }
  var lh="";
  for(var i=0;i<lienProps.length;i++){
    var pr=lienProps[i];
    var v=md.lien[pr.p]||"";
    lh+='<div class="erow">';
    lh+='<div class="eprop" title="'+pr.p+'">'+pr.p+'</div>';
    lh+='<input class="einp'+(v?" filled":"")+'" type="number" placeholder="'+(pr.lienDue||"0.00")+'" value="'+v+'" data-prop="'+pr.p+'" data-type="lien" oninput="updateEntry(this)">';
    lh+='<select class="esel'+(v?" yes":" no")+'" onchange="this.className=\'esel \'+(this.value===\'YES\'?\'yes\':\'no\')">';
    lh+='<option'+(v?" selected":"")+' value="YES">YES</option><option'+(!v?" selected":"")+' value="NO">NO</option></select>';
    lh+='</div>';
  }
  document.getElementById("lienList").innerHTML=lh;
  updateEntryCnts();
}
function updateEntry(inp) {
  var md=getMD(curMonth);
  var v=parseFloat(inp.value)||0;
  if(v>0){md[inp.dataset.type][inp.dataset.prop]=v;inp.classList.add("filled");}
  else{delete md[inp.dataset.type][inp.dataset.prop];inp.classList.remove("filled");}
  updateEntryCnts();
}
function updateEntryCnts() {
  var md=getMD(curMonth);
  document.getElementById("incCnt").textContent=Object.keys(md.income).length+" entered";
  document.getElementById("lienCnt").textContent=Object.keys(md.lien).length+" paid";
}

// ═══════════════════════════════════════
// MANAGE TAB
// ═══════════════════════════════════════
function pliIcon(t) {
  var icons={"RENTAL":"&#127968;","OWNER FINANCE":"&#128196;","PTO":"&#127970;","VACANT":"&#128273;","LAND":"&#127807;","OTHER":"&#128230;"};
  var bgs={"RENTAL":"#EEF6FF","OWNER FINANCE":"#E0F5EE","PTO":"#F3F0FF","VACANT":"#F5F5F3","LAND":"#FEF9C3","OTHER":"#FDF4FF"};
  return '<div class="pli-ico" style="background:'+(bgs[t]||"#F5F5F3")+'">'+(icons[t]||"&#127968;")+'</div>';
}
function renderMgrList() {
  document.getElementById("propCnt").textContent="("+S.properties.length+")";
  var html="";
  for(var i=0;i<S.properties.length;i++){
    var pr=S.properties[i];
    if(mgrSearch&&pr.p.toLowerCase().indexOf(mgrSearch.toLowerCase())<0) continue;
    var badge=pr.lienSt==="PAID OFF"?'<span class="pli-badge pb-off">Paid Off</span>':(pr.t==="VACANT"?'<span class="pli-badge pb-vac">Vacant</span>':'<span class="pli-badge pb-act">Active</span>');
    html+='<div class="pli'+(selProp===pr.p?" sel":"")+'" onclick="openMgrFor(\''+safeStr(pr.p)+'\')">';
    html+=pliIcon(pr.t);
    html+='<div><div class="pli-name">'+pr.p+'</div><div class="pli-type">'+pr.t+'</div></div>';
    html+=badge+'</div>';
  }
  document.getElementById("mgrList").innerHTML=html;
}
function filterMgrList(v){mgrSearch=v;renderMgrList();}
function openMgrFor(name) {
  selProp=name;
  renderMgrList();
  var pr=null;
  for(var i=0;i<S.properties.length;i++){if(S.properties[i].p===name){pr=S.properties[i];break;}}
  if(!pr) return;
  renderMgrForm(pr,false);
}
function showAddForm(){selProp=null;renderMgrList();renderMgrForm(null,true);}
function renderMgrForm(pr,isNew) {
  var f=pr||{p:"",t:"RENTAL",exp:0,lienDue:0,lienSt:"ACTIVE",notes:""};
  var types=["RENTAL","OWNER FINANCE","PTO","VACANT","LAND","OTHER"];
  var typeOpts="";
  for(var i=0;i<types.length;i++) typeOpts+='<option'+(f.t===types[i]?" selected":"")+'>'+types[i]+'</option>';
  var lienOpts='<option'+(f.lienSt==="ACTIVE"?" selected":"")+'>ACTIVE</option><option'+(f.lienSt==="PAID OFF"?" selected":"")+'>PAID OFF</option>';
  var safe=safeStr(f.p);
  var html='<div class="mf-inner">';
  html+='<div class="mf-title">'+(isNew?"Add New Property":f.p)+'</div>';
  html+='<div class="mf-sub">'+(isNew?"Fill in the details to add this property to your portfolio.":"Edit property details, lien information, and notes.")+'</div>';
  html+='<div class="mf-sec-title">Property Info</div>';
  html+='<div class="mf-grid">';
  html+='<div class="mf-field full"><label class="mf-lbl">Property Address / Name *</label>';
  html+='<input class="mf-inp" id="mf-name" type="text" value="'+f.p+'" placeholder="e.g. 1234 OAK ST"'+(isNew?'':' readonly style="background:#F0F0EE;color:#7A7870"')+'></div>';
  if(!isNew) html+='<div class="mf-field full"><span style="font-size:11px;color:#7A7870">Address cannot be changed. Remove and re-add to rename.</span></div>';
  html+='<div class="mf-field"><label class="mf-lbl">Property Type *</label><select class="mf-sel" id="mf-type">'+typeOpts+'</select></div>';
  html+='<div class="mf-field"><label class="mf-lbl">Expected Monthly Income ($)</label><input class="mf-inp" id="mf-exp" type="number" value="'+(f.exp||'')+'" placeholder="0.00" step="0.01"></div>';
  html+='</div>';
  html+='<div class="mf-sec-title">Lien Information</div>';
  html+='<div class="mf-grid">';
  html+='<div class="mf-field"><label class="mf-lbl">Monthly Lien Due ($)</label><input class="mf-inp" id="mf-liendue" type="number" value="'+(f.lienDue||'')+'" placeholder="0.00" step="0.01"></div>';
  html+='<div class="mf-field"><label class="mf-lbl">Lien Status</label><select class="mf-sel" id="mf-lienst">'+lienOpts+'</select></div>';
  html+='</div>';
  html+='<div class="mf-sec-title">Notes</div>';
  html+='<div class="mf-field full"><label class="mf-lbl">Notes (balance owed, foreclosure status, etc.)</label>';
  html+='<textarea class="mf-inp" id="mf-notes" rows="3" style="resize:vertical" placeholder="e.g. Still owes $1,243.00">'+f.notes+'</textarea></div>';
  html+='<div class="mf-actions">';
  if(!isNew) html+='<button class="btn-del" onclick="confirmDel(\''+safe+'\')">Remove</button>';
  html+='<button class="btn-cancel" onclick="cancelMgr()">Cancel</button>';
  html+='<button class="btn-save" onclick="'+(isNew?"saveNewProp()":"saveEditProp('"+safe+"')")+'">'+( isNew?"Add Property":"Save Changes")+'</button>';
  html+='</div></div>';
  document.getElementById("mgrForm").innerHTML=html;
}
function cancelMgr(){selProp=null;renderMgrList();document.getElementById("mgrForm").innerHTML='<div class="mgr-empty"><div style="font-size:2rem">&#127968;</div><div style="font-size:14px;font-weight:600;color:#3D3C39">Select a property to edit</div><div style="font-size:12px;line-height:1.6">Choose from the list or click Add New Property</div></div>';}
function saveNewProp() {
  var name=document.getElementById("mf-name").value.trim().toUpperCase();
  if(!name){toast("Property name is required",true);return;}
  for(var i=0;i<S.properties.length;i++){if(S.properties[i].p===name){toast("Property already exists",true);return;}}
  S.properties.push({p:name,t:document.getElementById("mf-type").value,exp:parseFloat(document.getElementById("mf-exp").value)||0,lienDue:parseFloat(document.getElementById("mf-liendue").value)||0,lienSt:document.getElementById("mf-lienst").value,notes:document.getElementById("mf-notes").value.trim()});
  S.properties.sort(function(a,b){return a.p.localeCompare(b.p);});
  selProp=name;
  saveData();renderMgrList();openMgrFor(name);
  toast(name+" added", false);
}
function saveEditProp(origName) {
  for(var i=0;i<S.properties.length;i++){
    if(S.properties[i].p===origName){
      S.properties[i].t=document.getElementById("mf-type").value;
      S.properties[i].exp=parseFloat(document.getElementById("mf-exp").value)||0;
      S.properties[i].lienDue=parseFloat(document.getElementById("mf-liendue").value)||0;
      S.properties[i].lienSt=document.getElementById("mf-lienst").value;
      S.properties[i].notes=document.getElementById("mf-notes").value.trim();
      break;
    }
  }
  saveData();renderMgrList();
  toast(origName+" updated", false);
}
function confirmDel(name) {
  document.getElementById("modalTitle").textContent="Remove Property";
  document.getElementById("modalBody").innerHTML="Are you sure you want to remove <strong>"+name+"</strong>? This will remove all its income and lien data. This cannot be undone.";
  document.getElementById("modalConfirm").onclick=function(){delProp(name);closeModal();};
  document.getElementById("overlay").classList.add("show");
}
function delProp(name) {
  S.properties=S.properties.filter(function(p){return p.p!==name;});
  var months=Object.keys(S.monthData);
  for(var i=0;i<months.length;i++){delete S.monthData[months[i]].income[name];delete S.monthData[months[i]].lien[name];}
  selProp=null;saveData();renderMgrList();cancelMgr();
  toast(name+" removed", true);
}
function closeModal(){document.getElementById("overlay").classList.remove("show");}
document.getElementById("overlay").addEventListener("click",function(e){if(e.target===e.currentTarget)closeModal();});

// ═══════════════════════════════════════
// INIT — always render first, then try Firebase
// ═══════════════════════════════════════
renderDash();

if (fbConfig) {
  loadScript("https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js", function(e1) {
    if (e1 instanceof Error) return;
    loadScript("https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js", function(e2) {
      if (e2 instanceof Error) return;
      try {
        window.firebase.initializeApp(fbConfig);
        fbDB = window.firebase.database();
        fbDB.ref(".info/connected").once("value", function(snap) {
          fbReady = true;
          loadFromFirebase();
        });
      } catch(e) {}
    });
  });
}
</script>
