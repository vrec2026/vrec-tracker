    '<td style="padding-left:16px;color:rgba(255,255,255,0.5);font-size:10px;text-transform:uppercase;letter-spacing:0.08em">TOTALS ('+vis.length+')</td><td></td>'+
    '<td>'+fmt(vInc)+'</td><td></td>'+
    '<td>'+fmt(vLien)+'</td><td></td>'+
    '<td style="color:'+(vNet>=0?"#2DD4A0":"#F87171")+'">'+(vNet<0?"-":"")+fmt(Math.abs(vNet))+'</td>';
}
