<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VREC Portfolio Tracker</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Arial,sans-serif;background:#F7F5F0;color:#141412;display:flex;flex-direction:column;height:100vh;overflow:hidden}
/* NAV */
.nav{display:flex;align-items:center;background:#111;padding:0 1rem;height:50px;flex-shrink:0;gap:4px;flex-wrap:nowrap;overflow-x:auto}
.nav-brand{color:#fff;font-weight:700;font-size:14px;margin-right:12px;white-space:nowrap}
.nav-btn{background:transparent;border:none;color:rgba(255,255,255,0.5);font-size:12px;padding:5px 12px;border-radius:5px;cursor:pointer;white-space:nowrap}
.nav-btn:hover{color:#fff;background:rgba(255,255,255,0.08)}
.nav-btn.active{background:#0C6349;color:#fff}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:8px;flex-shrink:0}
.month-sel{font-size:12px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;padding:4px 8px;border-radius:5px;cursor:pointer}
.month-sel option{background:#222}
.save-btn{font-size:12px;background:#1A9970;color:#fff;border:none;padding:6px 14px;border-radius:5px;cursor:pointer;white-space:nowrap}
.save-btn:hover{background:#2DD4A0;color:#083D2C}
/* TABS */
.tab{display:none;flex:1;overflow:hidden;flex-direction:column}
.tab.active{display:flex}
/* KPIs */
.kpis{display:flex;border-bottom:1px solid #D8D6CF;flex-shrink:0}
.kpi{flex:1;background:#fff;padding:12px 16px;border-right:1px solid #D8D6CF}
.kpi:last-child{border-right:none}
.kpi-lbl{font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#7A7870;margin-bottom:4px}
.kpi-val{font-size:22px;font-weight:700;color:#141412}
.kpi-val.pos{color:#0C6349}.kpi-val.neg{color:#B02A2A}
.kpi-sub{font-size:10px;color:#7A7870}
/* ALERTS */
.alert-bar{background:#FFF8ED;border-bottom:2px solid #C07D14;padding:6px 16px;font-size:12px;color:#C07D14;flex-shrink:0;display:flex;gap:8px;align-items:center;overflow-x:auto;white-space:nowrap}
.alert-chip{background:#FEF3DC;border:1px solid #C07D14;border-radius:20px;padding:2px 10px;font-size:11px}
/* TOOLBAR */
.toolbar{display:flex;align-items:center;gap:6px;padding:8px 16px;background:#fff;border-bottom:1px solid #D8D6CF;flex-shrink:0;flex-wrap:wrap}
.fpill{font-size:11px;padding:3px 12px;border-radius:20px;border:1px solid #D8D6CF;background:transparent;cursor:pointer}
.fpill.active{background:#0C6349;color:#fff;border-color:#0C6349}
.srch{margin-left:auto;font-size:12px;padding:5px 10px;border:1px solid #D8D6CF;border-radius:5px;width:160px;outline:none}
/* TABLE */
.tbl-wrap{flex:1;overflow:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{position:sticky;top:0;z-index:5}
th{background:#141412;color:rgba(255,255,255,0.7);font-size:10px;text-transform:uppercase;letter-spacing:0.08em;padding:9px 12px;text-align:left;white-space:nowrap}
td{padding:8px 12px;border-bottom:1px solid #F7F5F0;vertical-align:middle}
tr{background:#fff;cursor:pointer}
tr:hover td{background:#F0FBF7}
tr.r-alert td{background:#FFF8ED}
tr.r-neg td{background:#FFF5F5}
tr.r-strong td{background:#F0FBF4}
tr.r-vacant td{background:#F5F5F3;color:#7A7870}
.tfoot-row td{background:#141412!important;color:#fff!important;font-weight:700;position:sticky;bottom:0;font-size:11px}
/* BADGES */
.b{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px}
.b-ok{background:#DCFCE7;color:#166534}
.b-miss{background:#FCEAEA;color:#B02A2A}
.b-unp{background:#FEF3DC;color:#C07D14}
.b-na{background:#F5F5F3;color:#7A7870;border:1px solid #D8D6CF}
.chip{font-size:9px;font-weight:700;text-transform:uppercase;padding:2px 6px;border-radius:3px}
.c-rent{background:#EEF6FF;color:#1D5FAA}
.c-of{background:#E0F5EE;color:#083D2C}
.c-pto{background:#F3F0FF;color:#5B21B6}
.c-vac{background:#F5F5F3;color:#6B7280}
.c-land{background:#FEF9C3;color:#713F12}
.c-oth{background:#FDF4FF;color:#86198F}
.npos{color:#0C6349;font-weight:700}
.nneg{color:#B02A2A;font-weight:700}
/* DETAIL PANEL */
.detail{width:0;flex-shrink:0;background:#fff;border-left:1px solid #D8D6CF;overflow:hidden;transition:width 0.2s;display:flex;flex-direction:column}
.detail.open{width:300px}
.detail-inner{padding:1.25rem;overflow-y:auto;flex:1}
.d-prop{font-size:16px;font-weight:700;color:#141412;margin-bottom:2px}
.d-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #F7F5F0;font-size:12px}
.d-key{color:#7A7870}
.d-val{font-weight:700}
.d-sec{font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:#7A7870;font-weight:600;margin:12px 0 6px}
.d-inp{width:100%;font-size:12px;padding:6px 10px;border:1px solid #D8D6CF;border-radius:6px;margin-top:4px;outline:none;background:#F7F5F0}
.d-inp:focus{border-color:#1A9970}
.d-sel{width:100%;font-size:12px;padding:6px 10px;border:1px solid #D8D6CF;border-radius:6px;margin-top:4px;outline:none;background:#F7F5F0;cursor:pointer}
.d-btn{width:100%;margin-top:8px;padding:8px;background:#0C6349;color:#fff;border:none;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer}
.d-btn:hover{background:#1A9970}
.d-btn2{width:100%;margin-top:6px;padding:7px;background:transparent;border:1px solid #D8D6CF;border-radius:6px;font-size:12px;cursor:pointer;color:#3D3C39}
.confirm-msg{font-size:11px;color:#1A9970;padding:3px 0;display:none}
/* ENTRY TAB */
.entry-wrap{flex:1;overflow-y:auto;padding:1.5rem}
.entry-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;max-width:860px;margin:0 auto}
.ecard{background:#fff;border:1px solid #D8D6CF;border-radius:10px;overflow:hidden}
.ecard-hd{background:#141412;padding:10px 16px;display:flex;align-items:center;justify-content:space-between}
.ecard-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#fff}
.ecard-cnt{font-size:11px;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);padding:2px 8px;border-radius:20px}
.ehdr{display:grid;grid-template-columns:1fr 100px 80px;gap:6px;padding:5px 16px;background:#F7F5F0;border-bottom:1px solid #D8D6CF}
.ehdr span{font-size:9px;text-transform:uppercase;letter-spacing:0.1em;color:#7A7870;font-weight:600}
.elist{max-height:360px;overflow-y:auto}
.erow{display:grid;grid-template-columns:1fr 100px 80px;gap:6px;padding:7px 16px;border-bottom:1px solid #F7F5F0;align-items:center}
.erow:last-child{border:none}
.eprop{font-size:11px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.einp{font-size:11px;padding:4px 7px;border:1px solid #D8D6CF;border-radius:4px;background:#F7F5F0;width:100%;outline:none}
.einp.filled{background:#E0F5EE;border-color:#2DD4A0}
.esel{font-size:11px;padding:4px 5px;border:1px solid #D8D6CF;border-radius:4px;background:#F7F5F0;width:100%;cursor:pointer}
.esel.yes{background:#DCFCE7;border-color:#166534;color:#166534}
.esel.no{background:#FCEAEA;border-color:#B02A2A;color:#B02A2A}
/* MANAGE TAB */
.manage-layout{display:flex;flex:1;overflow:hidden}
.mgr-list{width:320px;flex-shrink:0;border-right:1px solid #D8D6CF;overflow-y:auto;background:#fff;display:flex;flex-direction:column}
.mgr-list-hd{padding:12px 16px;border-bottom:1px solid #D8D6CF;background:#fff;position:sticky;top:0;z-index:3}
.mgr-list-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#7A7870;margin-bottom:8px}
.mgr-srch{width:100%;font-size:12px;padding:6px 10px;border:1px solid #D8D6CF;border-radius:6px;outline:none;background:#F7F5F0}
.mgr-add{width:100%;margin-top:8px;padding:8px;background:#0C6349;color:#fff;border:none;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px}
.mgr-add:hover{background:#1A9970}
.pli{display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:1px solid #F7F5F0;cursor:pointer}
.pli:hover{background:#F7F5F0}
.pli.sel{background:#E0F5EE;border-left:3px solid #0C6349}
.pli-ico{width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.pli-name{font-size:12px;font-weight:600;color:#141412}
.pli-type{font-size:10px;color:#7A7870;text-transform:uppercase;letter-spacing:0.05em}
.pli-badge{margin-left:auto;font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px}
.pb-act{background:#DCFCE7;color:#166534}
.pb-off{background:#F5F5F3;color:#6B7280;border:1px solid #D8D6CF}
.pb-vac{background:#F5F5F3;color:#6B7280}
.mgr-form{flex:1;overflow-y:auto;padding:1.5rem}
.mf-inner{max-width:540px}
.mf-title{font-size:1.4rem;font-weight:700;color:#141412;margin-bottom:4px}
.mf-sub{font-size:12px;color:#7A7870;margin-bottom:1.5rem;line-height:1.6}
.mf-sec-title{font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:#7A7870;font-weight:700;margin-bottom:10px;padding-bottom:5px;border-bottom:1px solid #D8D6CF;margin-top:1.25rem}
.mf-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.mf-field{display:flex;flex-direction:column;gap:3px}
.mf-field.full{grid-column:1/-1}
.mf-lbl{font-size:11px;font-weight:600;color:#3D3C39}
.mf-inp{font-size:13px;padding:8px 10px;border:1px solid #D8D6CF;border-radius:6px;background:#F7F5F0;width:100%;outline:none}
.mf-inp:focus{border-color:#1A9970;background:#fff}
.mf-sel{font-size:13px;padding:8px 10px;border:1px solid #D8D6CF;border-radius:6px;background:#F7F5F0;width:100%;cursor:pointer;outline:none}
.mf-actions{display:flex;gap:8px;margin-top:1.25rem;padding-top:1rem;border-top:1px solid #D8D6CF}
.btn-save{flex:1;padding:10px;background:#0C6349;color:#fff;border:none;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer}
.btn-save:hover{background:#1A9970}
.btn-del{padding:10px 16px;background:#FCEAEA;color:#B02A2A;border:1px solid #B02A2A;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer}
.btn-del:hover{background:#B02A2A;color:#fff}
.btn-cancel{padding:10px 16px;background:transparent;border:1px solid #D8D6CF;border-radius:7px;font-size:13px;cursor:pointer;color:#3D3C39}
.mgr-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;color:#7A7870;gap:8px;padding:3rem;text-align:center}
/* FIREBASE TAB */
.fb-wrap{flex:1;overflow-y:auto;padding:1.5rem;background:#F7F5F0}
.fb-inner{max-width:580px;margin:0 auto}
.fb-card{background:#fff;border:1px solid #D8D6CF;border-radius:10px;overflow:hidden;margin-bottom:1.25rem}
.fb-card-hd{background:#141412;padding:10px 16px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.6)}
.fb-card-body{padding:1.25rem}
.fb-step{display:flex;gap:10px;margin-bottom:12px;align-items:flex-start}
.fb-step:last-child{margin-bottom:0}
.fb-num{width:22px;height:22px;border-radius:50%;background:#0C6349;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.fb-step-title{font-size:13px;font-weight:600;color:#141412;margin-bottom:2px}
.fb-step-body{font-size:12px;color:#7A7870;line-height:1.6}
.fb-step-body a{color:#1A9970}
.fb-step-body code{background:#F7F5F0;padding:1px 5px;border-radius:3px;font-size:11px;font-family:monospace}
.fb-inp{width:100%;font-size:13px;padding:8px 10px;border:1px solid #D8D6CF;border-radius:6px;background:#F7F5F0;margin-top:4px;outline:none}
.fb-inp:focus{border-color:#1A9970;background:#fff}
.fb-lbl{font-size:11px;font-weight:600;color:#3D3C39;margin-top:10px;display:block}
.fb-connect{width:100%;margin-top:12px;padding:10px;background:#1A9970;color:#fff;border:none;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer}
.fb-connect:hover{background:#0C6349}
.fb-status{margin-bottom:1.25rem}
.note{padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;line-height:1.6}
.note-warn{background:#FEF3DC;color:#7C4A00}
.note-info{background:#E0F5EE;color:#083D2C}
/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:999;display:none;align-items:center;justify-content:center}
.overlay.show{display:flex}
.modal{background:#fff;border-radius:12px;padding:1.5rem;max-width:360px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.2)}
.modal-title{font-size:16px;font-weight:700;color:#141412;margin-bottom:8px}
.modal-body{font-size:13px;color:#3D3C39;line-height:1.6;margin-bottom:1.25rem}
.modal-actions{display:flex;gap:8px;justify-content:flex-end}
.modal-cancel{padding:8px 16px;border:1px solid #D8D6CF;background:transparent;border-radius:6px;cursor:pointer;font-size:13px}
.modal-confirm{padding:8px 16px;background:#B02A2A;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:700}
/* TOAST */
.toast{position:fixed;bottom:20px;right:20px;background:#141412;color:#fff;padding:10px 16px;border-radius:8px;font-size:13px;font-weight:500;z-index:9999;display:none;border-left:3px solid #2DD4A0}
.toast.err{border-left-color:#B02A2A}
.toast.show{display:block}
</style>
</head>
<body>

<div class="nav">
  <span class="nav-brand">V VREC</span>
  <button class="nav-btn active" onclick="showTab('dash',this)">Dashboard</button>
  <button class="nav-btn" onclick="showTab('entry',this)">Enter Data</button>
  <button class="nav-btn" onclick="showTab('manage',this)">Manage Properties</button>
  <button class="nav-btn" onclick="showTab('firebase',this)">Firebase Setup</button>
  <div class="nav-right">
    <select class="month-sel" id="monthSel" onchange="changeMonth()">
      <option>January</option><option>February</option><option>March</option>
      <option selected>April</option>
      <option>May</option><option>June</option><option>July</option>
      <option>August</option><option>September</option><option>October</option>
      <option>November</option><option>December</option>
    </select>
    <button class="save-btn" id="saveBtn" onclick="saveData()">Save</button>
  </div>
</div>

<!-- DASHBOARD TAB -->
<div class="tab active" id="tab-dash">
  <div class="kpis" id="kpiBar"></div>
  <div class="alert-bar" id="alertBar" style="display:none"></div>
  <div class="toolbar">
    <button class="fpill active" onclick="setFilter('ALL',this)">All</button>
    <button class="fpill" onclick="setFilter('OWNER FINANCE',this)">Owner Finance</button>
    <button class="fpill" onclick="setFilter('RENTAL',this)">Rental</button>
    <button class="fpill" onclick="setFilter('PTO',this)">PTO</button>
    <button class="fpill" onclick="setFilter('VACANT',this)">Vacant</button>
    <button class="fpill" onclick="setFilter('ALERT',this)">Alerts</button>
    <input class="srch" type="text" placeholder="Search..." oninput="setSearch(this.value)">
  </div>
  <div style="display:flex;flex:1;overflow:hidden">
    <div class="tbl-wrap">
      <table>
        <thead><tr>
          <th style="padding-left:16px">Property</th><th>Type</th>
          <th>Income</th><th>Inc. Status</th>
          <th>Lien Paid</th><th>Lien Status</th><th>Net</th>
        </tr></thead>
        <tbody id="tBody"></tbody>
        <tfoot><tr class="tfoot-row" id="tFoot"></tr></tfoot>
      </table>
    </div>
    <div class="detail" id="detailPanel"><div class="detail-inner" id="detailInner"></div></div>
  </div>
</div>

<!-- ENTRY TAB -->
<div class="tab" id="tab-entry">
  <div class="entry-wrap">
    <div class="entry-grid">
      <div class="ecard">
        <div class="ecard-hd"><span class="ecard-title">Income Received</span><span class="ecard-cnt" id="incCnt">0 entered</span></div>
        <div class="ehdr"><span>Property</span><span>Amount ($)</span><span>Received?</span></div>
        <div class="elist" id="incList"></div>
      </div>
      <div class="ecard">
        <div class="ecard-hd"><span class="ecard-title">Lien Payments</span><span class="ecard-cnt" id="lienCnt">0 paid</span></div>
        <div class="ehdr"><span>Property</span><span>Amount ($)</span><span>Paid?</span></div>
        <div class="elist" id="lienList"></div>
      </div>
    </div>
    <div style="text-align:center;margin-top:1rem">
      <button class="btn-save" style="width:auto;padding:10px 28px" onclick="changeMonth();showTab('dash',document.querySelector('.nav-btn'))">Apply and View Dashboard</button>
    </div>
  </div>
</div>

<!-- MANAGE TAB -->
<div class="tab" id="tab-manage">
  <div class="manage-layout">
    <div class="mgr-list">
      <div class="mgr-list-hd">
        <div class="mgr-list-title">Properties <span id="propCnt" style="color:#1A9970"></span></div>
        <input class="mgr-srch" type="text" placeholder="Search..." oninput="filterMgrList(this.value)">
        <button class="mgr-add" onclick="showAddForm()">+ Add New Property</button>
      </div>
      <div id="mgrList"></div>
    </div>
    <div class="mgr-form" id="mgrForm">
      <div class="mgr-empty">
        <div style="font-size:2rem">🏠</div>
        <div style="font-size:14px;font-weight:600;color:#3D3C39">Select a property to edit</div>
        <div style="font-size:12px;line-height:1.6">Choose from the list or click Add New Property</div>
      </div>
    </div>
  </div>
</div>

<!-- FIREBASE TAB -->
<div class="tab" id="tab-firebase">
  <div class="fb-wrap">
    <div class="fb-inner">
      <h2 style="font-size:1.6rem;font-weight:700;color:#141412;margin-bottom:6px">Firebase Setup</h2>
      <p style="font-size:13px;color:#7A7870;margin-bottom:1.25rem;line-height:1.6">Connect to Firebase so your data saves to the cloud and works inside Google Sites.</p>

      <div class="fb-status" id="fbStatus"></div>

      <div class="fb-card">
        <div class="fb-card-hd">How to get your Firebase config</div>
        <div class="fb-card-body">
          <div class="fb-step">
            <div class="fb-num">1</div>
            <div>
              <div class="fb-step-title">Go to Firebase Console</div>
              <div class="fb-step-body">Open <a href="https://console.firebase.google.com" target="_blank">console.firebase.google.com</a> and sign in with Google.</div>
            </div>
          </div>
          <div class="fb-step">
            <div class="fb-num">2</div>
            <div>
              <div class="fb-step-title">Open your project</div>
              <div class="fb-step-body">Click <strong>vrec-portfolio</strong> to open it.</div>
            </div>
          </div>
          <div class="fb-step">
            <div class="fb-num">3</div>
            <div>
              <div class="fb-step-title">Go to Project Settings</div>
              <div class="fb-step-body">Click the <strong>gear icon</strong> next to "Project Overview" in the top-left sidebar, then click <strong>Project settings</strong>.</div>
            </div>
          </div>
          <div class="fb-step">
            <div class="fb-num">4</div>
            <div>
              <div class="fb-step-title">Register a Web App</div>
              <div class="fb-step-body">Scroll down to <strong>Your apps</strong>. Click the <strong>&lt;/&gt;</strong> web icon. Name it <code>vrec-app</code> and click Register. You will see a <code>firebaseConfig</code> block with your values.</div>
            </div>
          </div>
          <div class="fb-step">
            <div class="fb-num">5</div>
            <div>
              <div class="fb-step-title">Paste the 4 values below and click Connect</div>
              <div class="fb-step-body">Copy <code>apiKey</code>, <code>authDomain</code>, <code>databaseURL</code>, and <code>projectId</code> from the config block.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="fb-card">
        <div class="fb-card-hd">Your Firebase Config</div>
        <div class="fb-card-body">
          <label class="fb-lbl" style="margin-top:0">API Key</label>
          <input class="fb-inp" id="fb-apiKey" type="text" placeholder="AIzaSy...">
          <label class="fb-lbl">Auth Domain</label>
          <input class="fb-inp" id="fb-authDomain" type="text" placeholder="vrec-portfolio.firebaseapp.com">
          <label class="fb-lbl">Database URL <span style="font-weight:400;color:#7A7870">(ends in .firebaseio.com)</span></label>
