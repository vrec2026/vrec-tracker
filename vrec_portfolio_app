function typeChip(t) {
  var map = {"RENTAL":"c-rent","OWNER FINANCE":"c-of","PTO":"c-pto","VACANT":"c-vac","LAND":"c-land","OTHER":"c-oth"};
  var lbl = {"OWNER FINANCE":"O/F","PTO":"PTO","RENTAL":"Rent","VACANT":"Vacant","LAND":"Land","OTHER":"Other"};
  return '<span class="chip '+(map[t]||"c-oth")+'">'+(lbl[t]||t)+'</span>';
}
function renderDash() {
  var md = getMD(curMonth);
  var rows = [];
  for (var i=0; i<S.properties.length; i++) {
    var pr = S.properties[i];
    var inc = md.income[pr.p] || 0;
    var lien = md.lien[pr.p] || 0;
    var net = inc - lien;
    var isVac = pr.t==="VACANT"||pr.t==="LAND";
    var incSt = inc>0?"ok":(isVac?"na":"miss");
    var lienSt = pr.lienSt==="PAID OFF"?"na":(lien>0?"ok":"unp");
    var isAlert = (inc===0 && pr.exp>0)||(net < -500);
    rows.push({pr:pr,inc:inc,lien:lien,net:net,incSt:incSt,lienSt:lienSt,isAlert:isAlert});
  }
  // KPIs
  var totInc=0,totLien=0;
  for(var i=0;i<rows.length;i++){totInc+=rows[i].inc;totLien+=rows[i].lien;}
  var totNet=totInc-totLien;
  var actCnt=0,vacCnt=0;
  for(var i=0;i<rows.length;i++){
    if(rows[i].pr.t!=="VACANT"&&rows[i].pr.t!=="LAND")actCnt++;
    if(rows[i].pr.t==="VACANT")vacCnt++;
  }
  document.getElementById("kpiBar").innerHTML =
    '<div class="kpi"><div class="kpi-lbl">Income Received</div><div class="kpi-val pos">'+fmt(totInc)+'</div><div class="kpi-sub">'+curMonth+' 2026</div></div>'+
    '<div class="kpi"><div class="kpi-lbl">Liens Paid</div><div class="kpi-val">'+fmt(totLien)+'</div><div class="kpi-sub">'+curMonth+' 2026</div></div>'+
    '<div class="kpi"><div class="kpi-lbl">Portfolio Net</div><div class="kpi-val '+(totNet>=0?"pos":"neg")+'">'+(totNet<0?"-":"")+fmt(totNet)+'</div><div class="kpi-sub">After all liens</div></div>'+
    '<div class="kpi"><div class="kpi-lbl">Active Properties</div><div class="kpi-val">'+actCnt+'</div><div class="kpi-sub">'+vacCnt+' vacant</div></div>';
  // Alerts
  var alerts=[];
  for(var i=0;i<rows.length;i++){if(rows[i].isAlert)alerts.push(rows[i]);}
  var ab=document.getElementById("alertBar");
  if(alerts.length===0){ab.style.display="none";}
  else{
    ab.style.display="flex";
    var html='<strong>ATTENTION:</strong>';
    for(var i=0;i<Math.min(5,alerts.length);i++) html+=' <span class="alert-chip">'+alerts[i].pr.p+'</span>';
    if(alerts.length>5) html+=' <span class="alert-chip">+more</span>';
    ab.innerHTML=html;
  }
  // Filter
  var vis=[];
  for(var i=0;i<rows.length;i++){
    var r=rows[i];
    if(curFilter==="ALERT"&&!r.isAlert)continue;
    if(curFilter!=="ALL"&&curFilter!=="ALERT"&&r.pr.t!==curFilter)continue;
    if(curSearch&&r.pr.p.toLowerCase().indexOf(curSearch.toLowerCase())<0)continue;
    vis.push(r);
  }
  var bh={ok:'<span class="b b-ok">Received</span>',miss:'<span class="b b-miss">Missing</span>',na:'<span class="b b-na">N/A</span>',unp:'<span class="b b-unp">Unpaid</span>'};
  var bhl={ok:'<span class="b b-ok">Paid</span>',na:'<span class="b b-na">N/A</span>',unp:'<span class="b b-unp">Unpaid</span>'};
  var html="";
  for(var i=0;i<vis.length;i++){
    var r=vis[i];
    var rc=r.isAlert?"r-alert":r.net<0?"r-neg":(r.pr.t==="VACANT"||r.pr.t==="LAND")?"r-vacant":r.net>1500?"r-strong":"";
    var nh=r.net===0?'<span style="color:#7A7870">$0.00</span>':r.net>0?'<span class="npos">+'+fmt(r.net)+'</span>':'<span class="nneg">-'+fmt(Math.abs(r.net))+'</span>';
    html+='<tr class="'+rc+'" onclick="showDetail(\''+safeStr(r.pr.p)+'\')">';
    html+='<td style="padding-left:16px">'+(r.isAlert?'&#9888; ':'')+r.pr.p+'</td>';
    html+='<td>'+typeChip(r.pr.t)+'</td>';
    html+='<td>'+(r.inc>0?fmt(r.inc):'&mdash;')+'</td>';
    html+='<td>'+bh[r.incSt]+'</td>';
    html+='<td>'+(r.lien>0?fmt(r.lien):'&mdash;')+'</td>';
    html+='<td>'+bhl[r.lienSt]+'</td>';
    html+='<td>'+nh+'</td></tr>';
  }
  document.getElementById("tBody").innerHTML=html;
  var vInc=0,vLien=0;
  for(var i=0;i<vis.length;i++){vInc+=vis[i].inc;vLien+=vis[i].lien;}
  var vNet=vInc-vLien;
